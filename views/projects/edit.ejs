<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container" style="height:100vh;">
    <div class="card" style="width: 35vw;">
        <h2>Edit Project</h2>
        <form action="/projects/<%= project._id %>?_method=PUT" method="POST" style="margin-top: 20px;">
            <div class="form-group">
                <label for="name">Project Name</label>
                <input type="text" id="name" name="name" value="<%= project.name %>" required>
            </div>
            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="4"><%= project.description %></textarea>
            </div>
            <button type="submit" class="btn">Update Project</button>
            <a href="/projects/<%= project._id %>" class="btn btn-danger" style="margin-left: 10px;">Cancel</a>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>
